# Agent backend runtime settings
AGENT_BACKEND_PORT=8081

# Default LLM provider for the job-first course generation pipeline.
# Use an OpenAI-compatible /v1 endpoint.
AGENT_LLM_BASE_URL=https://api.openai.com/v1
AGENT_LLM_MODEL=gpt-4o-mini
AGENT_LLM_TIMEOUT_SECONDS=300
AGENT_LLM_MAX_RETRIES=3

# Required for real generation jobs.
# AGENT_LLM_API_KEY=

# Password to protect the settings panel (leave unset to disable).
# AGENT_SETTINGS_PASSWORD=
